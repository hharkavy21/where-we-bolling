rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // The users collection is readable and writable by anyone with the URL.
    // This is intentional for a small trusted friend group.
    // If you want more security, add Firebase Auth and check request.auth != null.
    match /users/{userId} {
      allow read:  if true;
      allow write: if true;
    }
  }
}
