# ─────────────────────────────────────────────────────────────────────────────
# Firebase Admin SDK credentials — used by the /api/notify serverless function.
# Add these as environment variables in your Vercel / Netlify project dashboard.
# NEVER commit real values to git.
# ─────────────────────────────────────────────────────────────────────────────

# Found in: Firebase Console → Project Settings → Service accounts
# → Generate new private key → download JSON and copy the fields below

FIREBASE_PROJECT_ID=your-project-id

FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Paste the entire private key including the -----BEGIN / END----- lines.
# In Vercel the literal \n characters are handled automatically.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_LONG_KEY_HERE\n-----END PRIVATE KEY-----\n"
